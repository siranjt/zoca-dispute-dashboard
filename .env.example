# Copy to .env.local and fill in. NEVER commit .env.local.
STRIPE_SECRET_KEY=rk_live_or_sk_live_...

# Anthropic Claude — used for LLM-based dispute signal scoring.
# Optional: if missing, the dashboard falls back to regex-only scoring.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

